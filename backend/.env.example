# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB Atlas ─────────────────────────────────────────────
# 1. Go to https://cloud.mongodb.com
# 2. Create a free cluster (M0)
# 3. Create a DB user under Security > Database Access
# 4. Allow your IP under Security > Network Access (or 0.0.0.0/0 for all)
# 5. Click "Connect" > "Drivers" and copy the connection string
# 6. Replace <username>, <password>, and <dbname> below
MONGO_URI=mongodb+srv://vashninadar123:Vash@1234@cluster0.lnixyxv.mongodb.net/?appName=Cluster0

# ── JWT ───────────────────────────────────────────────────────
# Use a long random string — at least 32 characters
JWT_SECRET=abc123
JWT_EXPIRES_IN=7d

# ── CORS / Client URL ─────────────────────────────────────────
# In development: http://localhost:3000
# In production:  https://your-deployed-frontend.com
CLIENT_URL=http://localhost:3000
